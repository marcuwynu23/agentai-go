# AgentAI Go - Configuration
# Copy to .env and set your values.

# Google Gemini API Token (required)
GEMINI_API_TOKEN=YOUR_GEMINI_API_TOKEN_HERE

# Gemini Model (optional, defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Rate limiting (optional)
REQUEST_DELAY=2000
MAX_RETRIES=3

# Workspace (optional, defaults to current directory)
# WORKSPACE_PATH=./workspace

# Logs (optional, leave empty to disable file logging)
# LOGS_PATH=./logs

# MCP URLs (optional, in-process servers used by default)
# MCP_FILE_HANDLING_URL=http://localhost:3001
# MCP_COMMAND_EXECUTION_URL=http://localhost:3002
# MCP_TEST_SERVER_URL=http://localhost:3003

LOG_LEVEL=info
LOG_MAX_FILE_SIZE=10MB
LOG_MAX_FILES=5
